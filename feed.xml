---
layout: none
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
{% assign pub_date = site.time | date: "%Y-%m-%dT%H:%M:%SZ" %}
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
  <title>{{ site.title }} by thechelsuk</title>
  <subtitle type="html">{{ site.description }}</subtitle>
  <link rel="self" type="application/atom+xml" href="{{ site.url }}/feed.xml" />
  <link rel="alternate" type="text/html" href="{{ site.url }}" />
  <generator>Jekyll</generator>
  <rights>{{ site.title }}</rights>
  <updated>{{ pub_date }}</updated>
  <author>
    <name>{{ site.title }}</name>
    <email>posts@nuchronic.uk</email>
    <uri>{{ site.url }}/</uri>
  </author>
  <id>{{ site.url }}/</id>

  {% for post in site.posts %}
     {% assign build_date = post.date | date: "%Y-%m-%dT%H:%M:%SZ" %}
     {% assign updated_date = post.modified | date: "%Y-%m-%dT%H:%M:%SZ" %}
      <entry>
        <title type="html"><![CDATA[{{ post_title_prefix }}{{ post.title | cdata_escape }}]]></title>
        <link rel="alternate" type="text/html" href="{{ site.url }}{{ post.url }}" />
        <id>{{ site.url }}{{ post.id }}</id>
        <published>{{ build_date }}</published>
        <updated>{% if post.modified %}{{ updated_date }}{% else %}{{ build_date }}{% endif %}</updated>
        <author>
          <name>{{ post.author }}</name>
          <uri>{{ post.link }}</uri>
        </author>
        <content type="html"><![CDATA[
          <ul>
            <li>Title: {{ post.title }}</li>
            <li>Author: {{ post.author }}</li>
            <li>Link: <a href="{{ post.link}}">{{ post.link }}</a></li>
            <li>Published: {{ post.date | date: "%Y-%m-%d" }}</li>
          </ul>
          <p><center>***</center></p>
          <p> // Published {{ post.date | date: "%Y-%m-%d" }} on nuchronic.uk - <i>The</i> webring for the chronically ill</p>
          <hr/>
          <p>💬 Thanks for keeping RSS alive. If you have an RSS feed please share it with thechelsuk on any of these <a href="https://links.thechels.uk">socials</a>.</p>
          <p>If you get value from this site, please share this post with someone you think will like it and support me with a <a href="https://ko-fi.com/thechelsuk">ko-fi</a>.</p>
        ]]></content>
      </entry>
  {% endfor %}
</feed>